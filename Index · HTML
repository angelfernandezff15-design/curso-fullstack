<!DOCTYPE html>
<html lang="es">

<head>
    <title>Angel — Desarrollador Web</title>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="style.css">
</head>

<body>

    <!-- NAVEGACIÓN -->
    <nav id="nav">
        <p class="nav-logo">Angel</p>
        <div class="nav-links">
            <a href="#sobre-mi">Sobre mí</a>
            <a href="#habilidades">Habilidades</a>
            <a href="#proyectos">Proyectos</a>
            <a href="#contacto">Contacto</a>
        </div>
    </nav>

    <!-- HERO -->
    <section id="hero">
        <div class="hero-contenido">
            <img src="imagenes/perfil.jpg" alt="Foto de Angel" class="foto-perfil">
            <h1>Hola, soy Angel</h1>
            <p class="descripcion">Desarrollador web en formación. Construyo páginas modernas con HTML y CSS.</p>
            <div class="hero-botones">
                <a href="#proyectos" class="boton">Ver proyectos</a>
                <a href="#contacto" class="boton boton-secundario">Contactarme</a>
            </div>
        </div>
    </section>

    <!-- SOBRE MÍ -->
    <section id="sobre-mi">
        <h2>Sobre mí</h2>
        <div class="sobre-mi-contenido">
            <p>Soy Ángel, estoy aprendiendo desarrollo web con un enfoque práctico e intensivo. Trabajo con HTML, CSS y herramientas modernas para construir proyectos reales.</p>
            <p>Mi objetivo es conseguir mis primeros clientes y proyectos freelance en los próximos meses.</p>
        </div>
    </section>

    <!-- HABILIDADES -->
    <section id="habilidades">
        <h2>Habilidades</h2>
        <div class="grid-habilidades">

            <div class="tarjeta-habilidad">
                <h3>HTML</h3>
                <p>Estructura semántica, formularios, etiquetas y atributos.</p>
            </div>

            <div class="tarjeta-habilidad">
                <h3>CSS</h3>
                <p>Flexbox, responsive design, variables CSS y animaciones.</p>
            </div>

            <div class="tarjeta-habilidad">
                <h3>Git</h3>
                <p>Control de versiones, commits y publicación en GitHub.</p>
            </div>

            <div class="tarjeta-habilidad">
                <h3>IA</h3>
                <p>Uso de ChatGPT, Claude y Copilot para acelerar el desarrollo.</p>
            </div>

        </div>
    </section>

    <!-- PROYECTOS -->
    <section id="proyectos">
        <h2>Proyectos</h2>
        <div class="grid-proyectos">

            <div class="tarjeta-proyecto">
                <h3>Landing personal</h3>
                <p>Mi primera web profesional con HTML y CSS avanzado.</p>
                <a href="#" class="boton boton-pequeño">Ver proyecto</a>
            </div>

            <div class="tarjeta-proyecto">
                <h3>Proyecto 2</h3>
                <p>Próximamente con JavaScript y APIs.</p>
                <a href="#" class="boton boton-pequeño">Ver proyecto</a>
            </div>

            <div class="tarjeta-proyecto">
                <h3>Proyecto 3</h3>
                <p>En construcción durante el curso.</p>
                <a href="#" class="boton boton-pequeño">Ver proyecto</a>
            </div>

        </div>
    </section>

    <!-- HERRAMIENTAS -->
    <section id="herramientas">
        <h2>Herramientas</h2>
        <div class="lista-herramientas">
            <span class="tag">VS Code</span>
            <span class="tag">GitHub</span>
            <span class="tag">ChatGPT</span>
            <span class="tag">Claude</span>
            <span class="tag">Copilot</span>
            <span class="tag">Obsidian</span>
        </div>
    </section>

    <!-- CONTACTO -->
    <section id="contacto">
        <h2>Contacto</h2>
        <p class="contacto-descripcion">¿Tenés un proyecto? Hablemos.</p>

        <form class="formulario">

            <label>Nombre</label>
            <input type="text" placeholder="Tu nombre" required>

            <label>Email</label>
            <input type="email" placeholder="tu@email.com" required>

            <label>Mensaje</label>
            <textarea placeholder="Contame tu proyecto..." required></textarea>

            <button type="submit" class="boton">Enviar mensaje</button>

        </form>
    </section>

    <!-- PIE DE PÁGINA -->
    <footer id="footer">
        <p>© 2026 Angel — Desarrollador Web</p>
        <div class="redes">
            <a href="#" class="boton-red">GitHub</a>
            <a href="#" class="boton-red">LinkedIn</a>
        </div>
    </footer>

</body>

</html>